import { useState } from 'react';
import { Users, Plus } from 'lucide-react';
import { useApp } from '../context/AppContext';
import type { IntegranteFamilia } from '../types';

export function CensoFamiliarPage() {
  const { agregarFamilia, familias } = useApp();

  const [jefeFamilia, setJefeFamilia] = useState('');
  const [cedulaJefe, setCedulaJefe] = useState('');
  const [telefono, setTelefono] = useState('');
  const [correo, setCorreo] = useState('');

  const [torre, setTorre] = useState('');
  const [bloque, setBloque] = useState('');
  const [apartamento, setApartamento] = useState('');

  const crearIntegranteVacio = (): IntegranteFamilia => ({
    id: crypto.randomUUID(),

    nombre: '',
    cedula: '',
    fechaNacimiento: '',

    sexo: 'MASCULINO',
    parentesco: 'OTRO',

    poseeDiscapacidad: false,
    poseeEnfermedad: false
  });

  const [integrantes, setIntegrantes] = useState<
    IntegranteFamilia[]
  >([
    crearIntegranteVacio()
  ]);

  const agregarNuevoIntegrante = () => {
    setIntegrantes(prev => [
      ...prev,
      crearIntegranteVacio()
    ]);
  };

  const actualizarIntegrante = (
    index: number,
    campo: keyof IntegranteFamilia,
    valor: any
  ) => {
    const copia = [...integrantes];

    copia[index] = {
      ...copia[index],
      [campo]: valor
    };

    setIntegrantes(copia);
  };

  const guardarFamilia = () => {

    if (
      !jefeFamilia ||
      !cedulaJefe ||
      !telefono ||
      !torre ||
      !bloque ||
      !apartamento
    ) {
      alert('Complete los datos obligatorios');
      return;
    }

    agregarFamilia({
      jefeFamilia,
      cedulaJefe,
      telefono,
      correo,
      torre,
      bloque,
      apartamento,
      integrantes
    });

    alert('Familia registrada correctamente');

    setJefeFamilia('');
    setCedulaJefe('');
    setTelefono('');
    setCorreo('');
    setTorre('');
    setBloque('');
    setApartamento('');

    setIntegrantes([
      crearIntegranteVacio()
    ]);
  };

  return (
    <div className="space-y-6">

      <div>
        <h1 className="text-2xl font-extrabold text-gray-900">
          Censo Familiar
        </h1>

        <p className="text-sm text-gray-500">
          Registro de grupos familiares de la comunidad.
        </p>
      </div>

      <div className="bg-white p-6 rounded-xl border border-gray-200 shadow-sm">

        <h2 className="font-bold text-lg mb-4">
          Datos del Jefe de Familia
        </h2>

        <div className="grid grid-cols-1 md:grid-cols-2 gap-4">

          <input
            value={jefeFamilia}
            onChange={e =>
              setJefeFamilia(e.target.value)
            }
            placeholder="Nombre completo"
            className="border p-2 rounded"
          />

          <input
            value={cedulaJefe}
            onChange={e =>
              setCedulaJefe(e.target.value)
            }
            placeholder="Cédula"
            className="border p-2 rounded"
          />

          <input
            value={telefono}
            onChange={e =>
              setTelefono(e.target.value)
            }
            placeholder="Teléfono"
            className="border p-2 rounded"
          />

          <input
            value={correo}
            onChange={e =>
              setCorreo(e.target.value)
            }
            placeholder="Correo"
            className="border p-2 rounded"
          />

        </div>

        <h2 className="font-bold text-lg mt-6 mb-4">
          Ubicación
        </h2>

        <div className="grid grid-cols-1 md:grid-cols-3 gap-4">

          <input
            value={torre}
            onChange={e =>
              setTorre(e.target.value)
            }
            placeholder="Torre"
            className="border p-2 rounded"
          />

          <input
            value={bloque}
            onChange={e =>
              setBloque(e.target.value)
            }
            placeholder="Bloque"
            className="border p-2 rounded"
          />

          <input
            value={apartamento}
            onChange={e =>
              setApartamento(e.target.value)
            }
            placeholder="Apartamento"
            className="border p-2 rounded"
          />

        </div>

        <div className="flex justify-between items-center mt-8 mb-4">

          <h2 className="font-bold text-lg">
            Integrantes
          </h2>

          <button
            type="button"
            onClick={agregarNuevoIntegrante}
            className="bg-indigo-600 text-white px-3 py-2 rounded-lg text-sm flex items-center gap-2"
          >
            <Plus size={16} />
            Agregar Integrante
          </button>

        </div>

        {integrantes.map((integrante, index) => (

          <div
            key={integrante.id}
            className="border rounded-lg p-4 mb-4 bg-gray-50"
          >

            <h3 className="font-bold mb-3">
              Integrante #{index + 1}
            </h3>

            <div className="grid grid-cols-1 md:grid-cols-2 gap-4">

              <input
                value={integrante.nombre}
                onChange={e =>
                  actualizarIntegrante(
                    index,
                    'nombre',
                    e.target.value
                  )
                }
                placeholder="Nombre"
                className="border p-2 rounded"
              />

              <input
                value={integrante.cedula}
                onChange={e =>
                  actualizarIntegrante(
                    index,
                    'cedula',
                    e.target.value
                  )
                }
                placeholder="Cédula"
                className="border p-2 rounded"
              />

              <input
                type="date"
                value={integrante.fechaNacimiento}
                onChange={e =>
                  actualizarIntegrante(
                    index,
                    'fechaNacimiento',
                    e.target.value
                  )
                }
                className="border p-2 rounded"
              />

              <select
                value={integrante.sexo}
                onChange={e =>
                  actualizarIntegrante(
                    index,
                    'sexo',
                    e.target.value
                  )
                }
                className="border p-2 rounded"
              >
                <option value="MASCULINO">
                  Masculino
                </option>

                <option value="FEMENINO">
                  Femenino
                </option>
              </select>

              <select
                value={integrante.parentesco}
                onChange={e =>
                  actualizarIntegrante(
                    index,
                    'parentesco',
                    e.target.value
                  )
                }
                className="border p-2 rounded md:col-span-2"
              >
                <option value="JEFE_FAMILIA">
                  Jefe de Familia
                </option>

                <option value="CONYUGE">
                  Cónyuge
                </option>

                <option value="HIJO">
                  Hijo
                </option>

                <option value="HIJA">
                  Hija
                </option>

                <option value="PADRE">
                  Padre
                </option>

                <option value="MADRE">
                  Madre
                </option>

                <option value="ABUELO">
                  Abuelo
                </option>

                <option value="ABUELA">
                  Abuela
                </option>

                <option value="OTRO">
                  Otro
                </option>
              </select>

            </div>

          </div>

        ))}

        <div className="bg-blue-50 border border-blue-200 rounded-lg p-4 mt-4">
          <p className="font-semibold text-blue-800">
            Integrantes registrados: {integrantes.length}
          </p>
        </div>

        <button
          onClick={guardarFamilia}
          className="mt-6 w-full bg-green-600 text-white py-3 rounded-lg font-bold hover:bg-green-700"
        >
          Guardar Familia
        </button>

      </div>

      <div className="bg-white rounded-xl border border-gray-200 shadow-sm p-6">

        <h2 className="font-bold text-lg mb-4 flex items-center gap-2">
          <Users size={18} />
          Familias Registradas
        </h2>

        <div className="space-y-3">

          {familias.map(familia => (
            <div
              key={familia.id}
              className="border rounded-lg p-4"
            >
              <div className="font-bold">
                {familia.jefeFamilia}
              </div>

              <div className="text-sm text-gray-500">
                {familia.torre} • {familia.bloque} • Apto {familia.apartamento}
              </div>

              <div className="text-sm mt-2">
                Integrantes: {familia.integrantes.length}
              </div>

              <div className="text-sm">
                Estado: {familia.estado}
              </div>
            </div>
          ))}

        </div>

      </div>

    </div>
  );
}